{#- Theme: cinema stylesheet. Palette + typography come from the bible; the theme
    supplies scale, motion, and composition. -#}
{%- set pal = bible.palette -%}
{%- set heading_font = bible.typography.heading | default('Fraunces', true) -%}
{%- set body_font = bible.typography.body | default('Inter', true) -%}
:root{
  --primary: {{ pal.primary | default('#C84B2F', true) }};
  --secondary: {{ pal.secondary | default('#8B2500', true) }};
  --accent: {{ pal.accent | default('#F5A623', true) }};
  --bg: {{ pal.background | default('#FDF8F0', true) }};
  --ink: {{ pal.text | default('#1C1C1C', true) }};
  --heading: "{{ heading_font }}", serif;
  --body: "{{ body_font }}", system-ui, sans-serif;
  --pad: clamp(1.25rem, 4vw, 4rem);
  --ease: cubic-bezier(.22,.8,.24,1);
}

*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--body);color:var(--ink);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased}
img{display:block;max-width:100%}
h1,h2,h3,.display{font-family:var(--heading);font-weight:700;line-height:1.04;letter-spacing:-.02em}

/* ---------- shared atoms ---------- */
.eyebrow{font-size:.78rem;font-weight:600;letter-spacing:.24em;text-transform:uppercase;color:var(--primary);margin-bottom:1.2rem}
.btn{display:inline-block;padding:.85rem 1.7rem;border-radius:999px;font-weight:600;font-size:.95rem;text-decoration:none;transition:transform .25s var(--ease), box-shadow .25s var(--ease), background .25s}
.btn:hover{transform:translateY(-2px)}
.btn-primary{background:var(--primary);color:#fff;box-shadow:0 10px 30px -12px var(--primary)}
.btn-primary:hover{background:var(--secondary)}
.btn-ghost{border:1.5px solid currentColor;color:inherit}
.btn-sm{padding:.5rem 1.1rem;font-size:.85rem}
.cta-row{display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1.8rem}
.stars{color:var(--accent);letter-spacing:.15em}
.section{padding:clamp(5rem,11vw,9rem) var(--pad);max-width:1200px;margin:0 auto}

/* reveal-on-scroll */
[data-reveal]{opacity:0;transform:translateY(28px);transition:opacity .9s var(--ease), transform .9s var(--ease)}
[data-reveal].is-in{opacity:1;transform:none}
@media (prefers-reduced-motion: reduce){
  [data-reveal]{opacity:1;transform:none;transition:none}
  html{scroll-behavior:auto}
}

/* ---------- progress bar ---------- */
.progress{position:fixed;top:0;left:0;right:0;height:3px;z-index:60;pointer-events:none}
.progress span{display:block;height:100%;width:0;background:var(--accent)}

/* ---------- topbar ---------- */
.topbar{position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;gap:1.5rem;padding:1rem var(--pad);color:#fff;transition:background .4s,color .4s,box-shadow .4s}
.topbar.is-solid{background:var(--bg);color:var(--ink);box-shadow:0 1px 0 rgba(0,0,0,.08)}
.wordmark{font-family:var(--heading);font-weight:900;font-size:1.25rem;letter-spacing:-.01em}
.topnav{display:flex;gap:1.4rem;margin-left:auto}
.topnav a{color:inherit;text-decoration:none;font-size:.9rem;font-weight:500;opacity:.85}
.topnav a:hover{opacity:1}
@media (max-width:640px){.topnav{display:none}.topbar{justify-content:space-between}}

/* ---------- hero ---------- */
.hero{position:relative;min-height:100svh;display:flex;align-items:flex-end;color:#fff;overflow:hidden;isolation:isolate}
.hero-media{position:absolute;inset:0;z-index:-2}
.hero-media img{width:100%;height:100%;object-fit:cover;animation:heroZoom 18s var(--ease) both}
@keyframes heroZoom{from{transform:scale(1.14)}to{transform:scale(1)}}
.hero-scrim{position:absolute;inset:0;z-index:-1;background:linear-gradient(180deg,rgba(8,8,12,.35) 0%,rgba(8,8,12,.15) 40%,rgba(8,8,12,.78) 100%)}
.hero-inner{padding:clamp(6rem,14vh,9rem) var(--pad) clamp(4rem,10vh,7rem);max-width:1200px;margin:0 auto;width:100%}
.hero .display{font-size:clamp(2.9rem,9vw,7.5rem);max-width:14ch;text-wrap:balance}
.hero .sub{margin-top:1.4rem;font-size:clamp(1.02rem,1.6vw,1.3rem);max-width:52ch;opacity:.92}
.hero .eyebrow{color:var(--accent)}
.rating-badge{margin-top:1.4rem;font-size:.9rem;opacity:.9}
.scroll-cue{position:absolute;bottom:1.6rem;right:var(--pad);width:1px;height:64px;background:rgba(255,255,255,.35);overflow:hidden}
.scroll-cue span{display:block;width:100%;height:40%;background:#fff;animation:cue 1.8s ease-in-out infinite}
@keyframes cue{from{transform:translateY(-110%)}to{transform:translateY(280%)}}
@media (prefers-reduced-motion: reduce){.hero-media img,.scroll-cue span{animation:none}}

/* ---------- marquee ---------- */
.marquee{background:var(--ink);color:var(--bg);overflow:hidden;padding:1.05rem 0;border-block:1px solid var(--ink)}
.marquee-track{display:flex;width:max-content;animation:marquee 26s linear infinite}
.marquee-run{display:flex;align-items:center;gap:2.2rem;padding-right:2.2rem}
.marquee-run span{font-family:var(--heading);font-weight:600;font-size:1.05rem;text-transform:uppercase;letter-spacing:.14em;white-space:nowrap}
.marquee-run i{color:var(--accent);font-style:normal}
@keyframes marquee{to{transform:translateX(-50%)}}
@media (prefers-reduced-motion: reduce){.marquee-track{animation:none}}

/* ---------- scroll-scrubbed chapters ---------- */
.chapters{position:relative;height:calc(var(--frames) * 90vh + 100vh);background:var(--ink)}
.chapters-sticky{position:sticky;top:0;height:100vh;overflow:hidden}
.frame{position:absolute;inset:0;opacity:0;transition:opacity .55s var(--ease);color:#fff}
.frame.is-active{opacity:1}
.frame img{width:100%;height:100%;object-fit:cover;transform:scale(1.06);transition:transform 1.2s var(--ease)}
.frame.is-active img{transform:scale(1)}
.frame::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(8,8,12,.18) 0%,rgba(8,8,12,.05) 45%,rgba(8,8,12,.72) 100%)}
.frame figcaption{position:absolute;left:var(--pad);right:var(--pad);bottom:clamp(2.4rem,7vh,4.5rem);z-index:1;display:flex;flex-direction:column;gap:.6rem}
.frame-index{font-size:.8rem;font-weight:600;letter-spacing:.28em;color:var(--accent)}
.frame-caption{font-size:clamp(1.7rem,4.6vw,3.6rem);max-width:18ch;text-wrap:balance}
.frame-progress{position:absolute;top:50%;right:calc(var(--pad) / 1.6);transform:translateY(-50%);z-index:2;display:flex;flex-direction:column;gap:.55rem}
.frame-progress span{width:5px;height:26px;border-radius:3px;background:rgba(255,255,255,.28);transition:background .3s,height .3s}
.frame-progress span.is-active{background:var(--accent);height:44px}
@media (prefers-reduced-motion: reduce){.frame{transition:none}.frame img,.frame.is-active img{transform:none;transition:none}}

/* ---------- about ---------- */
.about-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:clamp(2rem,5vw,4.5rem);align-items:center}
.about-copy .display{font-size:clamp(2rem,4.6vw,3.6rem);margin-bottom:1.4rem;text-wrap:balance}
.about-text{font-size:1.08rem;max-width:58ch}
.about-media{overflow:hidden;border-radius:14px}
.about-media img{aspect-ratio:4/5;object-fit:cover;width:100%;transform:translateY(calc(var(--py,0) * 1px)) scale(1.12);will-change:transform}
@media (max-width:820px){.about-grid{grid-template-columns:1fr}}

/* ---------- usps ---------- */
.usps-band{max-width:1200px}
.usps{list-style:none;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(1.5rem,3vw,2.5rem)}
.usps li{border-top:2px solid var(--ink);padding-top:1.1rem}
.usp-index{font-size:2rem;color:var(--primary);display:block;margin-bottom:.5rem}
.usps p{font-size:.98rem}

/* ---------- menu ---------- */
.menu-rows{list-style:none}
.menu-rows li{border-bottom:1px solid color-mix(in srgb, var(--ink) 18%, transparent);padding:1.5rem 0;transition:padding-left .35s var(--ease)}
.menu-rows li:first-child{border-top:1px solid color-mix(in srgb, var(--ink) 18%, transparent)}
.menu-rows li:hover{padding-left:.9rem}
.menu-row-head{display:flex;align-items:baseline;justify-content:space-between;gap:1rem}
.menu-row-head h3{font-size:clamp(1.5rem,3.4vw,2.4rem)}
.price{font-weight:600;color:var(--primary);white-space:nowrap}
.menu-rows p{margin-top:.45rem;max-width:60ch;opacity:.85}

/* ---------- reviews ---------- */
.reviews-band{text-align:left}
.pullquote{margin:0 0 3rem}
.pullquote:last-child{margin-bottom:0}
.pullquote blockquote{font-size:clamp(1.6rem,4vw,3rem);font-weight:600;max-width:26ch;text-wrap:balance}
.pullquote figcaption{margin-top:1rem;font-size:.9rem;opacity:.7}
.pullquote .stars{margin-bottom:.8rem}

/* ---------- gallery strip ---------- */
.strip{background:var(--ink);padding:clamp(3rem,7vw,5rem) 0}
.strip-track{display:flex;gap:1.2rem;overflow-x:auto;padding:0 var(--pad);scroll-snap-type:x mandatory;scrollbar-width:none}
.strip-track::-webkit-scrollbar{display:none}
.strip figure{flex:0 0 clamp(240px,32vw,420px);scroll-snap-align:center;color:var(--bg)}
.strip img{aspect-ratio:4/3;object-fit:cover;width:100%;border-radius:10px}
.strip figcaption{margin-top:.6rem;font-size:.82rem;opacity:.75}

/* ---------- visit ---------- */
.visit-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,5vw,4rem);align-items:start}
.address{font-size:clamp(1.4rem,2.8vw,2rem);margin-bottom:1.4rem;text-wrap:balance}
.hours{border-collapse:collapse;width:100%;max-width:22rem}
.hours td{padding:.4rem 0;border-bottom:1px dashed color-mix(in srgb, var(--ink) 25%, transparent);font-size:.95rem}
.hours td:last-child{text-align:right;font-weight:500}
.map iframe{width:100%;aspect-ratio:4/3;border:0;border-radius:14px}
@media (max-width:820px){.visit-grid{grid-template-columns:1fr}}

/* ---------- footer ---------- */
footer{background:var(--ink);color:var(--bg);padding:clamp(3rem,8vw,5rem) var(--pad) 2rem;text-align:center;overflow:hidden}
.footer-wordmark{font-size:clamp(3rem,14vw,11rem);line-height:.95;color:transparent;-webkit-text-stroke:1.5px color-mix(in srgb, var(--bg) 55%, transparent);white-space:nowrap;margin-bottom:1.6rem}
footer p{font-size:.9rem;opacity:.8}
.fineprint{margin-top:.8rem;font-size:.78rem;opacity:.5}

/* ---------- sticky cta ---------- */
.sticky-cta{position:fixed;bottom:1.2rem;left:50%;transform:translate(-50%,140%);transition:transform .5s var(--ease);z-index:55}
.sticky-cta.is-visible{transform:translate(-50%,0)}
@media (min-width:821px){.sticky-cta{left:auto;right:1.4rem;transform:translateY(140%)}.sticky-cta.is-visible{transform:translateY(0)}}
