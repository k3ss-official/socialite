{%- set sym = locale.currency_symbol -%}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Pitch — {{ bible.identity.name }}</title>
<style>
  :root { --ink: #16202b; --muted: #5c6b7a; --brand: #0f62fe; --gift: #0c7c46; --paper: #fff; }
  * { box-sizing: border-box; margin: 0; }
  body { font: 15px/1.55 -apple-system, system-ui, 'Segoe UI', sans-serif; color: var(--ink);
         background: #eef1f4; padding: 2rem 1rem; }
  .sheet { max-width: 860px; margin: auto; background: var(--paper); border-radius: 14px;
           padding: clamp(1.4rem, 4vw, 3rem); box-shadow: 0 14px 40px -18px rgb(0 0 0 / .25); }
  h1 { font-size: 1.7rem; } h2 { font-size: 1.15rem; margin: 2.2rem 0 .9rem;
       text-transform: uppercase; letter-spacing: .08em; font-size: .85rem; color: var(--muted); }
  .head { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;
          border-bottom: 2px solid var(--ink); padding-bottom: 1rem; }
  .head .meta { color: var(--muted); font-size: .85rem; text-align: right; }
  .gap { display: grid; grid-template-columns: auto 1fr; gap: .8rem; padding: .8rem 0;
         border-bottom: 1px solid #e3e8ee; align-items: start; }
  .gap .n { background: var(--ink); color: #fff; border-radius: 999px; width: 1.6rem; height: 1.6rem;
            display: grid; place-items: center; font-weight: 700; font-size: .8rem; }
  .gap b { display: block; }
  .gap .say { color: var(--muted); font-style: italic; }
  .gap .fix { font-size: .8rem; color: var(--brand); font-weight: 600; }
  .tiers { display: grid; gap: .9rem; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
  .tier { border: 1.5px solid #dfe5ec; border-radius: 12px; padding: 1rem; position: relative; }
  .tier.rec { border-color: var(--brand); box-shadow: 0 0 0 3px rgb(15 98 254 / .12); }
  .tier.rec::before { content: 'RECOMMENDED'; position: absolute; top: -.6rem; left: .8rem;
        background: var(--brand); color: #fff; font-size: .62rem; font-weight: 700;
        letter-spacing: .08em; padding: .15rem .5rem; border-radius: 999px; }
  .tier h3 { font-size: 1.02rem; }
  .tier .band { font-weight: 800; font-size: 1.15rem; margin: .3rem 0; }
  .tier .band small { font-weight: 500; color: var(--muted); }
  .tier p { font-size: .82rem; color: var(--muted); }
  .tier ul { padding-left: 1.05rem; font-size: .78rem; margin-top: .5rem; color: var(--ink); }
  table { width: 100%; border-collapse: collapse; font-size: .88rem; }
  th { text-align: left; font-size: .72rem; text-transform: uppercase; letter-spacing: .06em;
       color: var(--muted); padding: .45rem .5rem; border-bottom: 2px solid var(--ink); }
  td { padding: .55rem .5rem; border-bottom: 1px solid #e3e8ee; vertical-align: top; }
  .band-cell { white-space: nowrap; font-weight: 700; }
  .gift { color: var(--gift); font-weight: 600; }
  .gift::before { content: '🎁 '; }
  .kind { font-size: .7rem; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); }
  .fineprint { margin-top: 2rem; font-size: .75rem; color: var(--muted); }
  @media print { body { background: #fff; padding: 0; } .sheet { box-shadow: none; } }
</style>
</head>
<body>
<div class="sheet">
  <div class="head">
    <div>
      <h1>{{ bible.identity.name }}</h1>
      <div>{{ bible.identity.category | title }} · {{ locale.discovery.area_name }}</div>
    </div>
    <div class="meta">Prepared {{ pitch.generated_at[:10] }}<br>bible v{{ pitch.bible_version }} · internal</div>
  </div>

  <h2>What they're losing right now</h2>
  {% for g in pitch.gap_summary %}
  <div class="gap">
    <div class="n">{{ loop.index }}</div>
    <div>
      <b>{{ g.label }}{% if g.competitors_with %} — {{ g.competitors_with }} local rival{{ 's' if g.competitors_with != 1 }} have it{% endif %}</b>
      <span class="say">Say it like this: “{{ g.sell_line }}”</span>
      <div class="fix">Fixed by: {{ rung_by_key[g.rung_key].name }}</div>
    </div>
  </div>
  {% endfor %}

  <h2>The offer — pick one tier</h2>
  <div class="tiers">
    {% for t in pitch.tiers %}
    <div class="tier{% if t.recommended %} rec{% endif %}">
      <h3>{{ t.name }}</h3>
      <div class="band">{{ sym }}{{ t.monthly_low }}–{{ sym }}{{ t.monthly_high }}<small>/mo</small></div>
      <p>{{ t.pitch_line }}</p>
      <ul>{% for rk in t.rung_keys %}<li>{{ rung_by_key[rk].name }}</li>{% endfor %}</ul>
    </div>
    {% endfor %}
  </div>

  <h2>Line items underneath (each stands alone)</h2>
  <table>
    <tr><th>Service</th><th>Type</th><th>Includes</th><th>Monthly</th></tr>
    {% for r in pitch.rungs %}
    <tr>
      <td><b>{{ r.name }}</b>{% if r.term_months %}<div class="kind">{{ r.term_months }}-month minimum</div>{% endif %}
          {% if r.cadence_per_year %}<div class="kind">{{ r.cadence_per_year }}×/year, billed monthly</div>{% endif %}</td>
      <td class="kind">{{ r.kind | replace('_', ' ') }}</td>
      <td>
        {% for i in r.includes %}{{ i }}<br>{% endfor %}
        {% for g in r.gifts %}<span class="gift">{{ g }} — FREE</span><br>{% endfor %}
      </td>
      <td class="band-cell">{{ sym }}{{ r.monthly_low }}–{{ r.monthly_high }}</td>
    </tr>
    {% endfor %}
  </table>

  <p class="fineprint">Internal sales sheet — every line item is a separate agreement so one
  cancellation never takes the account. Free builds stay free while the rung above them is active.
  Generated by Socialite from bible v{{ pitch.bible_version }}.</p>
</div>
</body>
</html>
